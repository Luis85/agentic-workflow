filters:
  and:
    - 'file.path.startsWith("projects/")'
    - 'file.name == "followup-register.md"'
formulas:
  project: 'file.folder'
  status: 'note.status'
  last_updated: 'note.last_updated'
properties:
  formula.project:
    displayName: Project
  formula.status:
    displayName: Status
  formula.last_updated:
    displayName: Last updated
views:
  - type: table
    name: Project followups
    order:
      - formula.project
      - formula.status
      - formula.last_updated
