# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Obsidian vault-local state
.obsidian/
.trash/

# Dependencies
node_modules/

# Claude Code local state
.claude/settings.local.json
.claude/.session/
.claude/scheduled_tasks.lock

# Operational-bot scratch (FAILED-* recovery files, etc.)
.claude/cache/

# Worktrees — every topic branch lives under .worktrees/<slug>/.
# See docs/worktrees.md.
.worktrees/

# issue-breakdown skill — transient PR/issue body files staged for `gh ... --body-file`.
# Never committed; deleted at end of run. See docs/issue-breakdown-track.md.
.issue-breakdown-staging/

# caveman:compress backups — kept locally for diff/sanity checks only.
*.original.md

# Release pipeline staging — produced by `npm run build:release-archive`.
# Never committed; rebuilt fresh on every release-workflow run.
.release-staging/

# Publication-canonical lockfile — `package-lock.json` is the codebase form;
# `npm-shrinkwrap.json` is staged from it on the release runner before
# `npm pack` (T-V05-007). Never committed to the codebase.
npm-shrinkwrap.json

# Graphify cache and local run state — per-machine SHA256 tracking files
# and absolute-path metadata (REQ-GRAPH-005). See docs/how-to/use-graphify.md.
graph/cache/
graph/.graphify_*
